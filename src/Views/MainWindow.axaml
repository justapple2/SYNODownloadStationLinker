        </Style>
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="13,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#0067C0" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.TitleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinWidth" Value="46" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.PaneButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,7" />
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
        </Style>
        <Style Selector="PathIcon">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Foreground" Value="#3D3D3D" />
        </Style>
    </Window.Styles>

    <Border Classes="AppSurface" Margin="8">
        <Grid RowDefinitions="32,*">
            <Border Classes="TitleBar" PointerPressed="InputElement_OnPointerPressed">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="12,0" VerticalAlignment="Center">
                        <Image Height="18" Source="/Assets/SYNODSTool.png" Width="18" />
                        <TextBlock Classes="AppTitle" Text="SYNO Download Station Linker" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Classes="TitleButton" Click="MinBtn_OnClick" Content="-" Name="MinBtn" />
                        <Button Classes="TitleButton" Click="CloseBtn_OnClick" Content="x" Name="CloseBtn" />
                    </StackPanel>
                </Grid>
            </Border>

            <SplitView
                CompactPaneLength="58"
                DisplayMode="CompactInline"
                Grid.Row="1"
                IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
                OpenPaneLength="286"
                PanePlacement="Left">
                <SplitView.Pane>
                    <Border Classes="PaneRoot">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <StackPanel Margin="8,10,8,0" Spacing="8">
                                <Button Classes="PaneButton" Command="{Binding TogglePaneCommand}">
                                    <Grid ColumnDefinitions="30,*" ColumnSpacing="10">
                                        <PathIcon Data="{StaticResource navigation_regular}" />
                                        <TextBlock Classes="PaneLabel" Grid.Column="1" IsVisible="{Binding IsPaneOpen}" Text="连接与设置" />
                                    </Grid>
                                </Button>
                                <Border Classes="StatusPill" IsVisible="{Binding IsPaneOpen}" Margin="2,0">
                                    <TextBlock Classes="Meta" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                                </Border>
                                <StackPanel Spacing="2">
                                    <Button Classes="PaneButton" Command="{Binding NavigateToWorkspaceCommand}" CommandParameter="0">
                                        <Grid ColumnDefinitions="30,*" ColumnSpacing="10">
                                            <PathIcon Data="{StaticResource arrow_download_regular}" />
                                            <TextBlock Classes="PaneLabel" Grid.Column="1" IsVisible="{Binding IsPaneOpen}" Text="下载任务" />
                                        </Grid>
                                    </Button>
                                    <Button Classes="PaneButton" Command="{Binding NavigateToWorkspaceCommand}" CommandParameter="1">
                                        <Grid ColumnDefinitions="30,*" ColumnSpacing="10">
                                            <PathIcon Data="{StaticResource history_regular}" />
                                            <TextBlock Classes="PaneLabel" Grid.Column="1" IsVisible="{Binding IsPaneOpen}" Text="活动日志" />
                                        </Grid>
                                    </Button>
                                    <Button Classes="PaneButton" Command="{Binding NavigateToWorkspaceCommand}" CommandParameter="2">
                                        <Grid ColumnDefinitions="30,*" ColumnSpacing="10">
                                            <PathIcon Data="{StaticResource code_regular}" />
                                            <TextBlock Classes="PaneLabel" Grid.Column="1" IsVisible="{Binding IsPaneOpen}" Text="响应调试" />
                                        </Grid>
                                    </Button>
                                    <Button Classes="PaneButton" Command="{Binding NavigateToWorkspaceCommand}" CommandParameter="3">
                                        <Grid ColumnDefinitions="30,*" ColumnSpacing="10">
                                            <PathIcon Data="{StaticResource wrench_regular}" />
                                            <TextBlock Classes="PaneLabel" Grid.Column="1" IsVisible="{Binding IsPaneOpen}" Text="NAS 扩展" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" IsVisible="{Binding IsPaneOpen}" Margin="18,12,18,0">
                                <StackPanel>
                                    <TextBlock Classes="Label" Text="NAS 地址" />
                                    <TextBox Text="{Binding Uri, Mode=TwoWay}" Watermark="http://192.168.1.2:5000" />

                                    <TextBlock Classes="Label" Text="用户名" />
                                    <TextBox Text="{Binding UserName, Mode=TwoWay}" Watermark="DSM 用户名" />

                                    <TextBlock Classes="Label" Text="密码" />
                                    <TextBox PasswordChar="*" Text="{Binding Password, Mode=TwoWay}" Watermark="DSM 密码" />

                                    <TextBlock Classes="Label" Text="下载目录" />
                                    <TextBox Text="{Binding Destination, Mode=TwoWay}" Watermark="共享文件夹/子目录" />

                                    <StackPanel Margin="0,18,0,0" Spacing="8">
                                        <Button Classes="Primary" Command="{Binding InitCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <PathIcon Data="{StaticResource settings_regular}" Foreground="White" />
                                                <TextBlock Text="登录" />
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding TestCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <PathIcon Data="{StaticResource arrow_clockwise_regular}" />
                                                <TextBlock Text="测试连接" />
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding SaveCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <PathIcon Data="{StaticResource save_regular}" />
                                                <TextBlock Text="保存配置" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <StackPanel Grid.Row="2" IsVisible="{Binding IsPaneOpen}" Margin="18,10,18,18" Spacing="8">
                                <Button Command="{Binding StartListeningCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="{StaticResource play_regular}" />
                                        <TextBlock Text="开始监听剪贴板" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding StopListeningCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="{StaticResource navigation_regular}" />
                                        <TextBlock Text="停止监听" />
                                    </StackPanel>
                                </Button>
                                <ToggleSwitch Content="监听中" IsChecked="{Binding IsListening}" IsEnabled="False" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </SplitView.Pane>

                <SplitView.Content>
                    <TabControl Margin="18" SelectedIndex="{Binding SelectedWorkspaceIndex, Mode=TwoWay}">
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource arrow_download_regular}" />
                                    <TextBlock Text="下载任务" />
                                </StackPanel>
                            </TabItem.Header>
                            <Grid RowDefinitions="Auto,*" RowSpacing="14" Margin="0,12,0,0">
                                <Border Classes="Panel">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                        <StackPanel>
                                            <TextBlock Classes="SectionTitle" Text="创建下载任务" />
                                            <TextBlock Classes="Meta" Text="支持 magnet、ed2k、常见 HTTP/FTP 文件链接" />
                                        </StackPanel>
                                        <Button
                                            Classes="Primary"
                                            Command="{Binding CreateAndDownloadCommand}"
                                            Grid.Column="1"
                                            VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <PathIcon Data="{StaticResource arrow_download_regular}" Foreground="White" />
                                                <TextBlock Text="创建任务" />
                                            </StackPanel>
                                        </Button>
                                        <TextBox
                                            AcceptsReturn="True"
                                            Grid.ColumnSpan="2"
                                            Grid.Row="1"
                                            Height="72"
                                            Text="{Binding DownloadPath, Mode=TwoWay}"
                                            TextWrapping="Wrap"
                                            Watermark="粘贴下载地址" />
                                    </Grid>
                                </Border>

                                <Border Classes="Panel" Grid.Row="1">
                                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel>
                                                <TextBlock Classes="SectionTitle" Text="下载任务" />
                                                <TextBlock Classes="Meta" Text="{Binding LatestTaskTitle}" />
                                            </StackPanel>
                                            <Button Command="{Binding RefreshTasksCommand}" Grid.Column="1">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <PathIcon Data="{StaticResource arrow_clockwise_regular}" />
                                                    <TextBlock Text="刷新" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Grid Grid.Row="1" ColumnDefinitions="*,130" ColumnSpacing="16">
                                            <ProgressBar Value="{Binding LatestProgress}" VerticalAlignment="Center" />
                                            <TextBlock Classes="Meta" Grid.Column="1" Text="{Binding LatestTaskStatus}" />
                                        </Grid>

                                        <ScrollViewer Grid.Row="2">
                                            <ItemsControl ItemsSource="{Binding Tasks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:DownloadTaskProgress">
                                                        <Border
                                                            BorderBrush="#ECECEC"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="0,12">
                                                            <Grid ColumnDefinitions="*,96" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                                                <TextBlock
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding Title}"
                                                                    TextTrimming="CharacterEllipsis" />
                                                                <TextBlock
                                                                    Classes="Meta"
                                                                    Grid.Column="1"
                                                                    HorizontalAlignment="Right"
                                                                    Text="{Binding ProgressText}" />
                                                                <TextBlock
                                                                    Classes="Meta"
                                                                    Grid.Row="1"
                                                                    Text="{Binding Destination}"
                                                                    TextTrimming="CharacterEllipsis" />
                                                                <TextBlock
                                                                    Classes="Meta"
                                                                    Grid.Column="1"
                                                                    Grid.Row="1"
                                                                    HorizontalAlignment="Right"
                                                                    Text="{Binding SpeedText}" />
                                                                <ProgressBar
                                                                    Grid.ColumnSpan="2"
                                                                    Grid.Row="2"
                                                                    Value="{Binding Progress}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource history_regular}" />
                                    <TextBlock Text="活动日志" />
                                </StackPanel>
                            </TabItem.Header>
                            <Border Classes="Panel" Margin="0,12,0,0">
                                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                                    <TextBlock Classes="SectionTitle" Text="活动日志" />
                                    <ListBox Grid.Row="1" ItemsSource="{Binding Logs}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DownloadLogEntry">
                                                <Grid ColumnDefinitions="78,64,*" ColumnSpacing="10" Margin="0,5">
                                                    <TextBlock Classes="Meta" Text="{Binding TimeText}" />
                                                    <TextBlock Classes="Meta" Grid.Column="1" Text="{Binding Level}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Summary}" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource code_regular}" />
                                    <TextBlock Text="响应调试" />
                                </StackPanel>
                            </TabItem.Header>
                            <Border Classes="Panel" Margin="0,12,0,0">
                                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                                    <TextBlock Classes="SectionTitle" Text="响应调试" />
                                    <ScrollViewer Grid.Row="1">
                                        <SelectableTextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            Text="{Binding Response, Mode=OneWay}"
                                            TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource wrench_regular}" />
                                    <TextBlock Text="NAS 扩展" />
                                </StackPanel>
                            </TabItem.Header>
                            <Border Classes="Panel" Margin="0,12,0,0">
                                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                                    <TextBlock Classes="SectionTitle" Text="NAS API 扩展" />
                                    <TextBlock Classes="Meta" Grid.Row="1" Text="Synology Download Station 已接入；后续可在这里追加其他 NAS 下载服务。" />
                                    <ListBox Grid.Row="2">
                                        <ListBoxItem Content="Synology Download Station" IsSelected="True" />
                                        <ListBoxItem Content="预留：QNAP Download Station" IsEnabled="False" />
                                        <ListBoxItem Content="预留：Aria2 / Transmission" IsEnabled="False" />
                                    </ListBox>
                                </Grid>
                            </Border>
                        </TabItem>
                    </TabControl>
                </SplitView.Content>
            </SplitView>
        </Grid>
    </Border>
</Window>
